#: cinema/static/cinema/js/cart.js:137
msgid ""
"Перейти до кошика для\n"
"завершення покупки."
msgstr ""
"Go to cart to\n"
"complete your purchase."

#: cinema/static/cinema/js/cart.js:141
msgid "У кошику немає товарів."
msgstr "Your cart is empty."

#: cinema/static/cinema/js/cart.js:286
msgid "Разом:"
msgstr "Subtotal:"

#: cinema/static/cinema/js/main.js:46 cinema/static/cinema/js/main.js:60
msgid "💸 В кошику"
msgstr "💸 Added to cart"

#: cinema/static/cinema/js/main.js:127
msgid "Дане поле обов'язкове для заповнення."
msgstr "This field is required."

#: cinema/static/cinema/js/main.js:172 cinema/static/cinema/js/main.js:216
msgid "Ім’я має містити лише літери."
msgstr "Name must contain only letters."

#: cinema/static/cinema/js/main.js:209 cinema/static/cinema/js/main.js:217
msgid "Номер має бути у форматі +380XXXXXXXXX"
msgstr "Format: +380XXXXXXXXX"

#: cinema/static/cinema/js/utils/cart-item-controller.js:31
msgid "Даний товар можна придбати в кількості не більше 10 шт."
msgstr "You can buy up to 10 of this item."

#: cinema/static/cinema/js/utils/cart-item-controller.js:95
msgid "💸 Купити"
msgstr "💸 Add to cart"
